# Currency Symbol
NEXT_PUBLIC_CURRENCY_SYMBOL='₹'

# PostgreSQL Database Connection URL (Neon / Supabase / Local PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/letscart?schema=public"

# JWT Authentication Secret
JWT_SECRET="your_jwt_secret_key_here"

# Redis Cache & Live Inventory Lock URL
REDIS_URL="redis://localhost:6379"

# AI Microservice URL (FastAPI)
AI_SERVICE_URL="http://localhost:8000"

# Stripe & Stripe Connect API Keys
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key"
STRIPE_WEBHOOK_SECRET="whsec_your_stripe_webhook_secret"
